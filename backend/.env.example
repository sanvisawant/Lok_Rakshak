# .env — Lok-Rakshak Secrets
# Copy this file to backend/.env and fill in your values.
# NEVER commit the real .env — it's in .gitignore.

# ── Twilio — RPF SMS Tactical Ping ────────────────────────
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890    # Your Twilio number
TWILIO_TO_NUMBER=+919876543210    # RPF duty officer number

# ── Server host (used for QR code generation) ─────────────
# Set this to Laptop C's actual LAN IP before the demo
SERVER_HOST=192.168.1.100

# ── AI Models ─────────────────────────────────────────────────────────────
# Sarvam AI (Primary) and Gemini (Fallback) for Veritas Chatbot
SARVAM_API_KEY=your_sarvam_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
